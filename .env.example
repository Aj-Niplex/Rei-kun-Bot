# ══════════════════════════════════════════════════════════════════════════════
#                          REI-KUN BOT CONFIGURATION
#                 Copy this file to `.env` and fill your secrets.
#                 NEVER commit real tokens, API keys, or passwords.
# ══════════════════════════════════════════════════════════════════════════════

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CORE API CREDENTIALS (REQUIRED)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Discord Bot Token - Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# OpenRouter API Key - Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI Models (comma-separated, identity-friendly models first)
# See available models: https://openrouter.ai/models
OPENROUTER_MODELS=openrouter/auto,deepseek/deepseek-r1:free,meta-llama/llama-3.3-70b:free,google/gemini-2.5-pro:free

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# BOT IDENTITY & BEHAVIOR
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Prefix commands use this prefix. Slash commands still use Discord's native `/`.
BOT_PREFIX=!

# Bot version displayed in bot info/startup.
BOT_VERSION=v7.0.0

# Developer username displayed by the bot.
BOT_DEV=@your_username

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FILE PATHS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Emoji catalog JSON used by emoji helpers/sync commands.
EMOJI_CATALOG_FILE=knowledge/emoji_catalog.json

# Main system prompt for AI personality.
SYSTEM_PROMPT_FILE=ai/system_prompt.txt

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ACCESS CONTROL
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Admin usernames (comma-separated, case-insensitive).
BOT_ADMIN_USERS=your_discord_username

# Admin user IDs (comma-separated). Prefer IDs over usernames for reliability.
BOT_ADMIN_USER_IDS=123456789012345678

# Owner user IDs (comma-separated, for owner-only commands).
BOT_OWNER_USER_IDS=123456789012345678

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RESOURCE HUB (STUDY PLATFORM)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Channel ID where resource codes trigger auto-DM (0 = disabled).
RESOURCE_TRIGGER_CHANNEL_ID=0

# User ID to notify on resource add/edit/missing code (0 = disabled).
RESOURCE_NOTIFY_USER_ID=0

# User IDs allowed to add/edit resources (comma-separated, empty = none).
RESOURCE_ALLOWED_USER_IDS=

# Role IDs allowed to add/edit resources (comma-separated, empty = none).
RESOURCE_ALLOWED_ROLE_IDS=

# Allow server administrators to manage resources (true/false).
RESOURCE_ALLOW_ADMINISTRATOR=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ERROR REPORTING & AI ERROR HANDLER
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Enable AI-powered error handling.
ERROR_HANDLER_ENABLED=true

# Email address shown in config for reports.
# NOTE: core/ownership.py may override the final destination for founder reports.
ERROR_REPORT_EMAIL=you@example.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SMTP CONFIGURATION FOR SENDING ERROR EMAILS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# For Gmail, use an App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=you@example.com

# Recommended: store encrypted values using `python encrypt_secrets.py`.
# Example encrypted format: ENC:gAAAAA...
SMTP_PASSWORD=your_gmail_app_password_or_encrypted_value_here

# Optional: SendGrid API Key if using SendGrid instead of SMTP.
SENDGRID_API_KEY=
